# Copy to .env for local use. NEVER commit .env.
# In cloud routines, set these as environment variables on the routine itself.

# Alpaca mode: paper (default, safe) or live (real money).
# The alpaca.sh wrapper picks the endpoint based on this unless ALPACA_ENDPOINT is set explicitly.
ALPACA_MODE=paper

# Optional explicit overrides. Leave unset to let ALPACA_MODE decide.
# Paper: https://paper-api.alpaca.markets/v2
# Live:  https://api.alpaca.markets/v2
# ALPACA_ENDPOINT=
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2

# Alpaca API keys. Paper and live accounts have SEPARATE key pairs — generate the pair that matches ALPACA_MODE.
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Perplexity (research)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar

# Discord (notifications — posts to a channel via webhook)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
